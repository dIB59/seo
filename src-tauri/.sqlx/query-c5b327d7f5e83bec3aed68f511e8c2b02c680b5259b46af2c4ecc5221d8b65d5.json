  "query": "\n            SELECT\n                id as \"id!\", job_id, page_id, type as issue_type, severity, message, details, created_at\n            FROM issues\n            WHERE job_id = ?\n            ORDER BY\n                CASE severity\n                    WHEN 'critical' THEN 1\n                    WHEN 'warning' THEN 2\n                    ELSE 3\n                END,\n                type ASC\n            ",
