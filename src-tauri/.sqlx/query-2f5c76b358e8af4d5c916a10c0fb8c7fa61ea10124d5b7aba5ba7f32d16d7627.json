  "query": "\n            SELECT\n                pi.id as \"id!\", pi.page_id, pi.src, pi.alt, pi.width, pi.height,\n                pi.loading, pi.is_decorative\n            FROM page_images pi\n            JOIN pages p ON p.id = pi.page_id\n            WHERE p.job_id = ?\n            ORDER BY pi.page_id, pi.id\n            ",
