{
  "db_name": "SQLite",
  "query": "\n            SELECT \n                id, url, status, progress, \n                total_pages, total_issues, created_at,\n                COUNT(*) OVER() as \"total_count!\"\n            FROM jobs\n            WHERE url LIKE ?1 AND status LIKE ?2\n            ORDER BY created_at DESC\n            LIMIT ?3 OFFSET ?4\n            ",
